###############################################################################
# Default: normalize line endings (LF in repo, CRLF on Windows checkout)
###############################################################################
* text=auto eol=crlf

###############################################################################
# Source code — always text, diff as csharp where applicable
###############################################################################
*.cs         text diff=csharp
*.csproj     text
*.slnx       text
*.sln        text
*.xaml       text
*.props      text
*.targets    text

###############################################################################
# Web / script assets
###############################################################################
*.html       text
*.css        text
*.js         text
*.json       text
*.xml        text
*.yml        text
*.yaml       text

###############################################################################
# Markdown / docs
###############################################################################
*.md         text

###############################################################################
# Config / shell
###############################################################################
*.ps1        text
*.sh         text eol=lf
*.editorconfig text
*.gitignore  text
*.gitattributes text

###############################################################################
# Resource strings
###############################################################################
*.resw       text

###############################################################################
# Binary assets — never normalize
###############################################################################
*.png        binary
*.jpg        binary
*.ico        binary
*.woff2      binary
*.pfx        binary
*.snk        binary
